generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider = "postgresql"
}

model User {
  id        Int      @id @default(autoincrement())
  email     String   @unique
  password  String
  status    String   @default("active")
  role      Role     @default(User)
  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt
  bitacoras  Bitacora[]
  documents Document[]
}

model Document {
  id          Int      @id @default(autoincrement())
  title       String
  content     String   // El texto procesado
  keywords    String   // Palabras clave (pueden ser separadas por comas)
  status      String   @default("processed")
  createdAt   DateTime @default(now())
  // Relación con el usuario
  userId      Int
  user        User     @relation(fields: [userId], references: [id])
}

model Bitacora {
  id          Int      @id @default(autoincrement())
  action      String   // Ejemplo: "CREATE_USER"
  entityType  String   // Ejemplo: "User"
  entityId    Int      // El ID del usuario afectado
  details     String?  // Descripción de lo que pasó
  createdAt   DateTime @default(now())

  // Relación con el usuario que hizo la acción
  userId      Int
  usuario     User     @relation(fields: [userId], references: [id])
}

enum Role {
  ADMIN
  User
}
